{
  "name": "market-intelligence-api",
  "version": "0.1.0",
  "description": "US Market Intelligence AI Platform — Node.js Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "ts-node --transpile-only src/index.ts",
    "setup": "prisma generate && prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "db:dev": "docker compose up -d postgres && npx prisma migrate dev",
    "db:prod": "npx prisma migrate deploy",
    "db:reset": "npx prisma migrate reset --force",
    "prisma:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "rebuild": "npm run clean && npm run build",
    "serve": "npm run build && node dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "mathjs": "^13.2.2",
    "ml-hclust": "^3.1.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "sentiment": "^5.0.2",
    "simple-statistics": "^7.8.7",
    "technicalindicators": "^3.1.0",
    "yahoo-finance2": "^3.13.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "nodemon": "^3.1.9",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
