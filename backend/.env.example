# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/market_analyser"

# API Keys
FRED_API_KEY=""
FINNHUB_API_KEY=""
ANTHROPIC_API_KEY=""

# AI Model Config
AI_MODEL_SCREENING="claude-haiku-4-5-20251001"
AI_MODEL_DEEP="claude-sonnet-4-6"
AI_CACHE_HOURS="24"

# Scheduler
MARKET_CLOSE_HOUR_UTC="21"
SCHEDULER_ENABLED="true"

# Portfolio Defaults
MAX_POSITION_PCT="0.10"
KELLY_FRACTION="0.5"
INITIAL_CASH_BALANCE="0.0"

# Auth (leave empty to disable)
APP_API_KEY=""

# Encryption (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
DB_ENCRYPTION_KEY=""

# Watchlist
DEFAULT_TICKERS="AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,JPM,V,JNJ,UNH,XOM,PG,HD,MA"
